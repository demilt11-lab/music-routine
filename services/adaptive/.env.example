# --- Adaptive service configuration ---
NODE_ENV=development
PORT=8787

# Supabase (required). Service role key bypasses RLS — keep it server-only.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# Comma-separated CORS allowlist (use the web app origin in production).
ALLOWED_ORIGINS=http://localhost:8080

# Optional: OpenAI-compatible LLM gateway. Unset => deterministic engine only.
AI_GATEWAY_URL=https://ai.gateway.lovable.dev/v1
AI_API_KEY=
AI_MODEL=google/gemini-2.5-flash

# Optional music providers.
JAMENDO_CLIENT_ID=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional Redis for fleet-wide cache + rate limiting.
REDIS_URL=
