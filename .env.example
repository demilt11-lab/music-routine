# BioMusic — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit a .env file with real credentials — it is git-ignored.

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL (from Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon / public key — safe to expose in the browser
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_KEY

# ── Spotify (optional — enables Spotify integration) ────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Add your production URL + /settings to the Redirect URIs list
VITE_SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID

# ── Error Tracking (optional — recommended for production) ──────────────────
# Create a project at https://sentry.io and copy the DSN
VITE_SENTRY_DSN=

# ── Supabase Edge Function Secrets (set in Supabase dashboard, NOT here) ────
# These are server-side only. Set them via:
#   Supabase Dashboard → Edge Functions → Manage Secrets
#
#   SPOTIFY_CLIENT_SECRET   — Spotify app secret
#   VAPID_PRIVATE_KEY       — Web Push VAPID private key
#   VAPID_PUBLIC_KEY        — Web Push VAPID public key
