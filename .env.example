# --- BioMusic web app (Vite) ---
# Copy to .env and fill in. Only VITE_-prefixed values are exposed to the
# browser, so never put secrets here. Validated at startup by src/lib/env.ts.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Base URL of the adaptive service (services/adaptive). Optional in local dev:
# when unset, the client falls back to the bundled deterministic engine.
VITE_ADAPTIVE_SERVICE_URL=http://localhost:8787
